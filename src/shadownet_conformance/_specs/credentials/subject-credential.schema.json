{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sh4dow.org/schemas/v0/credentials/subject-credential.schema.json",
  "title": "Shadownet Subject Credential (JWT payload)",
  "description": "Payload of a Verifiable Credential JWT (typ=vc+jwt) issued by an SCA. See RFC-0003.",
  "type": "object",
  "required": ["iss", "sub", "iat", "exp", "jti", "shadownet:v", "vc"],
  "properties": {
    "iss":  { "type": "string", "pattern": "^did:" },
    "sub":  { "type": "string", "pattern": "^did:" },
    "iat":  { "type": "integer", "minimum": 0 },
    "exp":  { "type": "integer", "minimum": 0 },
    "jti":  { "type": "string", "format": "uri" },
    "shadownet:v": { "const": "0.1" },

    "vc": {
      "type": "object",
      "required": ["@context", "type", "credentialSubject"],
      "properties": {
        "@context": {
          "type": "array",
          "items": { "type": "string", "format": "uri" },
          "contains": { "const": "https://www.w3.org/ns/credentials/v2" }
        },
        "type": {
          "type": "array",
          "items": { "type": "string" },
          "contains": { "const": "VerifiableCredential" }
        },
        "credentialSubject": {
          "type": "object",
          "required": ["id", "level", "subjectType"],
          "properties": {
            "id":          { "type": "string", "pattern": "^did:" },
            "level":       { "type": "string", "format": "uri" },
            "subjectType": { "enum": ["person", "organization"] }
          }
        },
        "credentialStatus": {
          "type": "object",
          "required": ["type", "statusListIndex", "statusListCredential"],
          "properties": {
            "type":                 { "const": "BitstringStatusListEntry" },
            "statusListIndex":      { "type": "string", "pattern": "^[0-9]+$" },
            "statusListCredential": { "type": "string", "format": "uri" }
          }
        }
      }
    }
  }
}
